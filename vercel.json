{
  "build": {
    "env": {
      "NODE_VERSION": "16",
      "MONGO_URI": "@mongo_uri", 
      "JWT_SECRET": "@jwt_secret"
    }
  },
  "functions": {
    "api/auth/signup": {
      "runtime": "nodejs16.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ]
}
